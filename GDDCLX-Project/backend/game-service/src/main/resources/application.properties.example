# ========================================
# 游戏服务 — 应用配置文件模板
# 使用方法：复制此文件为 application.properties 并填入真实值
# ========================================

# 游戏服务端口
server.port=8081

# 数据库配置（与主服务共享同一数据库，请替换为真实值）
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://localhost:3306/wechat?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
spring.datasource.username=你的数据库用户名
spring.datasource.password=你的数据库密码

# HikariCP连接池
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5

# MyBatis配置
mybatis.mapper-locations=classpath:mapper/*.xml
mybatis.type-aliases-package=com.example.game.domain
mybatis.configuration.map-underscore-to-camel-case=true
mybatis.configuration.log-impl=org.apache.ibatis.logging.stdout.StdOutImpl

# Nacos配置（不使用请设为false）
spring.cloud.nacos.config.enabled=false
spring.cloud.nacos.discovery.enabled=false

# 定时任务
spring.task.scheduling.enabled=true

# 员工默认密码
app.default-password=你的默认密码
